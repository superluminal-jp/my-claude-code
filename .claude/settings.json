{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "defaultMode": "acceptEdits",
  "model": "claude-opus-4-8",
  "fallbackModel": ["claude-sonnet-4-6", "claude-haiku-4-5-20251001"],
  "effortLevel": "high",
  "tui": "fullscreen",
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": true,

  "statusLine": {
    "type": "command",
    "command": "\"$HOME\"/.claude/hooks/statusline.sh"
  },

  "enableAllProjectMcpServers": true,

  "permissions": {
    "allow": [
      "mcp__aws-knowledge__*",
      "mcp__aws-documentation__*",
      "mcp__bedrock-agentcore__*",
      "mcp__strands-agents__*",
      "mcp__google-developer-knowledge__*",
      "mcp__microsoft-learn__*",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git fetch *)",
      "Bash(tests/run-*.sh)",
      "Bash(bash tests/run-*.sh)",
      "Bash(scripts/check-mcp-consistency.sh)",
      "Bash(bash scripts/check-mcp-consistency.sh)",
      "Bash(shellcheck *)",
      "Bash(shfmt *)",
      "Bash(jq *)",
      "Bash(yamllint *)",
      "Bash(git commit *)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git pull *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)"
    ]
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/session-start.sh",
            "timeout": 300,
            "statusMessage": "Preparing lint toolchain for this session…"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/pre-bash.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|Delete",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/pre-edit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/post-edit-format.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/user-prompt-submit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "speckit\\.(specify|clarify|plan|tasks|implement|checklist|analyze|taskstoissues|constitution|converge)",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/speckit-expand-update.sh",
            "timeout": 300,
            "statusMessage": "Updating Spec Kit before /speckit-* command…"
          }
        ]
      }
    ]
  }
}
