{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "defaultMode": "acceptEdits",
  "model": "claude-sonnet-4-6",
  "effortLevel": "medium",
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": true,

  "enableAllProjectMcpServers": true,

  "permissions": {
    "allow": [
      "mcp__aws-knowledge__*",
      "mcp__aws-documentation__*",
      "mcp__bedrock-agentcore__*",
      "mcp__strands-agents__*",
      "mcp__google-developer-knowledge__*",
      "mcp__microsoft-learn__*",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git fetch *)"
    ],
    "ask": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git pull *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)",
      "Read(**/*.pem)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/pre-bash.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Edit|Write|Delete",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/pre-edit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/post-edit-format.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/user-prompt-submit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptExpansion": [
      {
        "matcher": "speckit\\.(specify|clarify|plan|tasks|implement|checklist|analyze|taskstoissues|constitution)",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.claude/hooks/speckit-expand-update.sh",
            "timeout": 300,
            "statusMessage": "Updating Spec Kit before /speckit-* command…"
          }
        ]
      }
    ]
  }
}
