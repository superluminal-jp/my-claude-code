{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "defaultMode": "acceptEdits",
  "model": "claude-sonnet-4-6",
  "effortLevel": "high",
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": true,

  "enableAllProjectMcpServers": true,

  "permissions": {
    "allow": [
      "mcp__aws-knowledge__*",
      "mcp__aws-documentation__*",
      "mcp__bedrock-agentcore__*",
      "mcp__strands-agents__*",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git pull *)",
      "Bash(git fetch *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials/**)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-bash.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
